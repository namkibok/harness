# 특정 확장자 전체 제외 (모든 YAML 파일)
setup.inf*

# 특정 파일 이름 제외
setup.inf


# 1. 보안 및 설정 파일 (가장 중요!)
.env
.env.*
*.pem
*.key
cert/
secrets/
credentials.json

# 2. 의존성 및 빌드 결과물 (AI가 읽으면 속도만 느려짐)
node_modules/
dist/
build/
out/
target/

# 3. 로그 및 데이터베이스
*.log
*.sqlite
*.db
data/
uploads/

# 4. OS 관련 및 임시 파일
.DS_Store
Thumbs.db
.tmp/